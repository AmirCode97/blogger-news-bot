  <!-- Infinite Scroll Script -->
  <script type='text/javascript'>
    // Standard Infinite Scroll Logic
    (function() {
      var loading = false;
      // Note: Selector updated for new layout structure
      var container = document.querySelector(&#39;.homepage-loop&#39;); 
      var nextLink = document.getElementById(&#39;blog-pager-older-link&#39;);
      var nextPageUrl = nextLink ? nextLink.href : null;

      if(container &amp;&amp; nextLink) {
        window.addEventListener(&#39;scroll&#39;, function() {
          if(loading || !nextPageUrl) return;
          if((window.innerHeight + window.scrollY) &gt;= document.body.offsetHeight - 800) {
            loading = true;
            fetch(nextPageUrl).then(r =&gt; r.text()).then(html =&gt; {
               var doc = new DOMParser().parseFromString(html, &#39;text/html&#39;);
               var newPosts = doc.querySelectorAll(&#39;.post-card&#39;);
               newPosts.forEach(p =&gt; container.appendChild(p));
               
               var newNext = doc.getElementById(&#39;blog-pager-older-link&#39;);
               if(newNext) nextPageUrl = newNext.href; else nextPageUrl = null;
               loading = false;
            });
          }
        });
      }
    })();
  </script>

