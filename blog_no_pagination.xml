  <b:skin><![CDATA[
    /* --- POLITICS & HUMAN RIGHTS THEME VARIABLES --- */
    :root {
      --primary: #c0392b; /* Alert Red */
      --primary-dark: #a93226;
      --bg-dark: #0a0a0a; /* Deep Black */
      --bg-card: #141414;
      --text-main: #ecf0f1;
      --text-muted: #95a5a6;
      --border: #2c3e50;
      --header-bg: #050505;
    }

    /* --- RESET & BASE --- */
    * { box-sizing: border-box; outline: none; }
    body {
      margin: 0; padding: 0;
      font-family: 'Vazir', sans-serif;
      background-color: var(--bg-dark);
      color: var(--text-main);
      direction: rtl;
      font-size: 14px;
      line-height: 1.7;
    }
    a { text-decoration: none; color: inherit; transition: 0.3s; }
    a:hover { color: var(--primary); }
    img { max-width: 100%; height: auto; display: block; }
    ul { list-style: none; padding: 0; margin: 0; }

    /* --- TOP ALERT BAR (BREAKING NEWS) --- */
    .alert-bar {
      background: var(--primary);
      color: #fff;
      font-size: 12px;
      padding: 8px 0;
      display: flex;
      align-items: center;
    }
    .alert-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 15px;
      display: flex;
      width: 100%;
    }
    .alert-title {
      background: #000;
      padding: 2px 10px;
      border-radius: 4px;
      font-weight: 900;
      margin-left: 15px;
      white-space: nowrap;
      text-transform: uppercase;
    }
    .alert-marquee { flex: 1; font-weight: bold; }

    /* --- HEADER --- */
    .site-header {
      background: var(--header-bg);
      padding: 25px 0;
      border-bottom: 1px solid var(--border);
    }
    .header-content {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 15px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .logo-text h1 {
      font-size: 32px;
      font-weight: 900;
      letter-spacing: -1px;
      margin: 0;
    }
    .logo-text span { color: var(--primary); }
    .header-date { color: var(--text-muted); font-size: 12px; }
    
    /* Language Switcher */
    .lang-switcher {
      display: flex;
      gap: 10px;
    }
    .lang-btn {
      display: flex;
      align-items: center;
      gap: 5px;
      background: rgba(255,255,255,0.05);
      border: 1px solid #333;
      padding: 6px 12px;
      border-radius: 20px;
      font-size: 11px;
      color: #aaa;
      transition: 0.3s;
    }
    .lang-btn:hover {
      background: var(--primary);
      color: #fff;
      border-color: var(--primary);
    }
    .lang-btn img {
      width: 18px;
      height: 12px;
      border-radius: 2px;
    }

    /* --- NAVIGATION --- */
    .main-nav {
      background: #0f0f0f;
      border-bottom: 2px solid var(--border);
      position: sticky; top: 0; z-index: 999;
    }
    .nav-inner {
      max-width: 1200px; margin: 0 auto; padding: 0 15px;
      display: flex; height: 50px; align-items: center;
    }
    .nav-links { display: flex; gap: 25px; height: 100%; }
    .nav-links a {
      display: flex; align-items: center; height: 100%;
      font-weight: 700; font-size: 13px; color: #ccc;
      border-top: 3px solid transparent;
    }
    .nav-links a:hover { color: #fff; border-top-color: var(--primary); }
    .nav-search { margin-right: auto; }
    .nav-search input {
      background: #222; border: 1px solid #333; color: #fff;
      padding: 6px 15px; border-radius: 20px 0 0 20px; font-family: inherit; font-size: 12px;
      width: 150px;
    }
    .search-btn {
      background: var(--primary);
      border: none;
      color: #fff;
      padding: 6px 12px;
      border-radius: 0 20px 20px 0;
      cursor: pointer;
      transition: 0.3s;
    }
    .search-btn:hover { background: var(--primary-dark); }

    /* --- MAIN LAYOUT --- */
    .main-container {
      max-width: 1200px; margin: 40px auto; padding: 0 15px;
      display: grid; grid-template-columns: 800px 1fr; gap: 40px;
    }

    /* --- FEATURED SECTION (First Post) --- */
    .hero-post {
      position: relative;
      margin-bottom: 40px;
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }
    .hero-thumb {
      width: 100%; height: 450px; object-fit: cover;
      filter: brightness(0.7);
      transition: 0.5s;
    }
    .hero-post:hover .hero-thumb { filter: brightness(0.9) scale(1.05); }
    .hero-content {
      position: absolute; bottom: 0; right: 0; left: 0;
      padding: 40px;
      background: linear-gradient(to top, rgba(0,0,0,0.9), transparent);
    }
    .hero-cat {
      background: var(--primary); color: #fff;
      padding: 4px 10px; font-size: 11px; font-weight: bold;
      border-radius: 2px; text-transform: uppercase;
      margin-bottom: 10px; display: inline-block;
    }
    .hero-title {
      font-size: 36px; font-weight: 900; color: #fff;
      margin: 10px 0; line-height: 1.3; text-shadow: 0 2px 4px rgba(0,0,0,0.5);
    }
    .hero-meta { color: #ccc; font-size: 12px; }

    /* --- HOMEPAGE LAYOUT --- */
    .homepage-loop {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
    }
    .hero-post, .news-grid-title {
      width: 100%;
    }
    .post-card {
      background: var(--bg-card);
      border: 1px solid #222;
      border-radius: 6px; overflow: hidden;
      display: flex; flex-direction: column;
      transition: 0.3s;
      width: calc(50% - 10px); /* 2 Column Grid */
    }
    
    /* FIX: Hide duplicate first post in grid if it appears */
    /* If the loop logic fails and prints the first post as a card, this hides it */
    /* .homepage-loop .post-card:first-of-type { display: none; } */
    /* Only enable if duplication persists. For now, we trust the XML logic. */
    
    .post-card:hover { border-color: var(--primary); transform: translateY(-3px); }
    .card-thumb { height: 180px; overflow: hidden; position: relative; }
    .card-thumb img { width: 100%; height: 100%; object-fit: cover; transition: 0.5s; }
    .post-card:hover .card-thumb img { transform: scale(1.1); }
    .card-body { padding: 20px; }
    .card-title { font-size: 16px; font-weight: 800; margin-bottom: 10px; line-height: 1.5; height: 48px; overflow: hidden; }
    .card-excerpt { font-size: 13px; color: var(--text-muted); height: 60px; overflow: hidden; margin-bottom: 15px; }

    /* --- SIDEBAR WIDGETS --- */
    .widget-box {
      background: var(--bg-card);
      border: 1px solid #222;
      border-radius: 6px;
      padding: 25px;
      margin-bottom: 30px;
    }
    .widget-header {
      font-size: 14px; font-weight: 900;
      color: #fff; text-transform: uppercase;
      border-bottom: 2px solid var(--primary);
      padding-bottom: 10px; margin-bottom: 20px;
      letter-spacing: 1px;
    }

    /* Statistics Widget */
    .stat-row { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid #222; }
    .stat-row:last-child { border: none; }
    .stat-label { font-size: 13px; color: #aaa; }
    .stat-val { font-weight: bold; color: #fff; }
    .stat-graph { height: 4px; background: #222; width: 100%; margin-top: 5px; border-radius: 2px; overflow: hidden; }
    .stat-bar { height: 100%; background: var(--primary); }

    /* Quote Widget */
    .quote-box { text-align: center; }
    .quote-img { width: 80px; height: 80px; border-radius: 50%; object-fit: cover; margin: 0 auto 15px; border: 2px solid var(--primary); }
    .quote-text { font-style: italic; font-size: 14px; color: #ccc; margin-bottom: 15px; line-height: 1.6; }
    .quote-author { font-weight: bold; color: #fff; font-size: 12px; }

    /* Footer */
    .main-footer {
      background: #050505; border-top: 1px solid #222;
      padding: 60px 0 30px; margin-top: 60px;
    }
    .footer-inner { max-width: 1200px; margin: 0 auto; padding: 0 15px; display: grid; grid-template-columns: repeat(4, 1fr); gap: 40px; }
    .footer-col h4 { color: #fff; border-bottom: 2px solid var(--primary); display: inline-block; padding-bottom: 5px; margin-bottom: 20px; }
    .footer-col ul li { margin-bottom: 10px; border-bottom: 1px dotted #222; padding-bottom: 5px; }

    /* --- RESPONSIVE --- */
    @media (max-width: 1000px) {
      .main-container { display: flex; flex-direction: column; }
      .hero-title { font-size: 24px; }
      .news-grid { grid-template-columns: 1fr; }
      .footer-inner { grid-template-columns: 1fr; text-align: center; }
    }
    
    /* Hide Default Pager */
    
  ]]></b:skin>
</head>

<body>

  <!-- 1. ALERT BAR (Live from Iran International) -->
  <div class='alert-bar'>
    <div class='alert-inner'>
      <div class='alert-title'>فوری</div>
      <div class='alert-marquee'>
        <marquee direction='right' id='live-ticker' scrollamount='6'>
          در حال دریافت اخبار...
        </marquee>
      </div>
    </div>
  </div>
  
  <script>
    // === ADVANCED DEDUPLICATION and TICKER SYSTEM ===
    document.addEventListener(&#39;DOMContentLoaded&#39;, function() {
       
       // 1. Advanced Duplicate Removal (Hero vs Grid)
       // This function scans ALL grid items and removes any that match the Hero post.
       function removeDuplicates() {
           var heroLink = document.querySelector(&#39;.hero-post a&#39;);
           if (!heroLink) return;
           
           var heroUrl = heroLink.href;
           var gridCards = document.querySelectorAll(&#39;.post-card&#39;);
           
           gridCards.forEach(function(card) {
               var cardLink = card.querySelector(&#39;a&#39;);
               if (cardLink &amp;&amp; cardLink.href === heroUrl) {
                   card.remove(); // Completely remove the duplicate element from DOM
                   console.log(&#39;Duplicate post removed:&#39;, heroUrl);
               }
           });
       }
       
       // Run immediately
       removeDuplicates();
       
       // 2. Live News Ticker (Iran Intl)
       // Uses CORS Proxy + Cache Busting for fresh news
       var rssUrl = &#39;https://www.iranintl.com/fa/rss&#39;;
       var timestamp = new Date().getTime();
       var proxyUrl = &#39;https://corsproxy.io/?&#39; + encodeURIComponent(rssUrl) + &#39;&amp;_t=&#39; + timestamp;
       
       fetch(proxyUrl)
        .then(function(res) { 
            if (!res.ok) throw new Error(&quot;Network response was not ok&quot;);
            return res.text(); 
        })
        .then(function(str) {
            var parser = new DOMParser();
            var xml = parser.parseFromString(str, &quot;text/xml&quot;);
            var items = xml.getElementsByTagName(&quot;item&quot;);
            var headlines = [];
            
            // Extract top 10 headlines
            for(var i=0; i &lt; Math.min(items.length, 10); i++) {
                var t = items[i].getElementsByTagName(&quot;title&quot;)[0];
                if(t) headlines.push(t.textContent);
            }
            
            // Display
            if(headlines.length &gt; 0) {
               var ticker = document.getElementById(&#39;live-ticker&#39;);
               if(ticker) ticker.innerHTML = headlines.join(&#39; \u2022 &#39;); // Bullet separator
            } else {
               throw new Error(&quot;No news items found&quot;);
            }
        })
        .catch(function(e) {
            console.error(&#39;Ticker Error:&#39;, e);
            var ticker = document.getElementById(&#39;live-ticker&#39;);
            if(ticker) ticker.innerHTML = &quot;پوشش لحظه&#8204;ای مهم&#8204;ترین اخبار ایران و جهان&quot;;
        });
    });
  </script>

